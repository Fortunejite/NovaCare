{
  "name": "novacare",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "shared"
  ],
  "scripts": {
    "build": "npm run build -w shared && npm run build -w backend && npm run build -w frontend",
    "build:shared": "npm run build -w shared",
    "build:backend": "npm run build -w backend",
    "build:frontend": "npm run build -w frontend",
    "lint": "npm run lint -w shared && npm run lint -w backend && npm run lint -w frontend",
    "lint:shared": "npm run lint -w shared",
    "lint:backend": "npm run lint -w backend",
    "lint:frontend": "npm run lint -w frontend",
    "dev:backend": "npm run dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "dev": "npm run dev:backend",
    "start:backend": "npm run start -w backend",
    "start:frontend": "npm run start -w frontend",
    "start": "npm run start:backend",
    "db:generate": "npm run db:generate -w backend",
    "db:migrate": "npm run db:migrate -w backend",
    "db:deploy": "npm run db:deploy -w backend",
    "db:reset": "npm run db:reset -w backend",
    "db:studio": "npm run db:studio -w backend"
  }
}