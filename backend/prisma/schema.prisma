generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  active
  blocked
}

enum Role {
  admin
  patient
  doctor
  receptionist
  pharmacist
  labTechnician
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum PatientStatus {
  active
  admitted
  discharged
  deceased
}

enum AppointmentStatus {
  scheduled
  completed
  cancelled
}

enum AppointmentType {
  consultation
  follow_up
  checkup
  emergency
}

enum LabRequestStatus {
  pending
  completed
  cancelled
}

enum PrescriptionStatus {
  pending
  dispensed
  cancelled
}

enum LabTestType {
  blood_test
  urine_test
  x_ray
  mri
  ct_scan
  ecg
  ultrasound
  biopsy
  genetic_test
  allergy_test
  pathology_test
}

model AuthMethod {
  id           String       @id @default(uuid())
  userId       String
  provider     AuthProvider
  providerId   String? // For third-party providers like GOOGLE
  passwordHash String? // Only for LOCAL provider
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("auth_methods")
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  role         Role
  refreshToken String?    @unique
  status       UserStatus @default(active)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  authMethods         AuthMethod[]
  doctor              Doctor?
  receptionist        Receptionist?
  pharmacist          Pharmacist?
  labTechnician       LabTechnician?
  patient             Patient?
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("password_reset_tokens")
}

model Department {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  doctors Doctor[]

  @@map("departments")
}

model Doctor {
  id                String   @id @default(uuid())
  firstName         String
  lastName          String
  phoneNumber       String
  address           String
  consultationFee   Float
  yearsOfExperience Int
  licenseNumber     String
  userId            String   @unique
  departmentId      String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  department   Department    @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  appointments Appointment[]

  @@map("doctors")
}

model Receptionist {
  id          String   @id @default(uuid())
  firstName   String
  lastName    String
  gender      String
  dateOfBirth DateTime
  phoneNumber String
  address     String
  userId      String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  appointments Appointment[]

  @@map("receptionists")
}

model Pharmacist {
  id            String   @id @default(uuid())
  firstName     String
  lastName      String
  gender        String
  phoneNumber   String
  address       String
  qualification String
  licenseNumber String
  userId        String   @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id])
  prescriptions Prescription[]

  @@map("pharmacists")
}

model LabTechnician {
  id            String   @id @default(uuid())
  firstName     String
  lastName      String
  gender        String
  phoneNumber   String
  address       String
  qualification String
  userId        String   @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  labRequests LabRequest[]
  user        User         @relation(fields: [userId], references: [id])

  @@map("lab_technicians")
}

model Patient {
  id          String   @id @default(uuid())
  firstName   String
  lastName    String
  gender      String
  dateOfBirth DateTime
  bloodGroup  String
  genotype    String

  phoneNumber String
  address     String
  city        String
  state       String

  maritalStatus String

  weight Float
  height Float

  emergencyContactName         String
  emergencyContactPhone        String
  emergencyContactRelationship String

  allergies      String?
  medicalHistory String?
  status         PatientStatus @default(active)

  registrationDate DateTime @default(now())
  updatedAt        DateTime @updatedAt

  userId       String        @unique
  user         User          @relation(fields: [userId], references: [id])
  appointments Appointment[]
  bills        Bill[]

  @@map("patients")
}

model Appointment {
  id             String            @id @default(uuid())
  receptionistId String
  patientId      String
  doctorId       String
  datetime       DateTime
  reason         String
  type           AppointmentType   @default(consultation)
  status         AppointmentStatus @default(scheduled)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  patient      Patient       @relation(fields: [patientId], references: [id])
  doctor       Doctor        @relation(fields: [doctorId], references: [id])
  receptionist Receptionist  @relation(fields: [receptionistId], references: [id])
  consultation Consultation?

  @@map("appointments")
}

model Consultation {
  id            String   @id @default(uuid())
  appointmentId String   @unique
  diagnosis     String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointment   Appointment    @relation(fields: [appointmentId], references: [id])
  prescriptions Prescription[]
  labRequests   LabRequest[]

  @@map("consultations")
}

model Medication {
  id            String    @id @default(uuid())
  name          String
  description   String?
  price         Float
  stockQuantity Int
  weight        Float? // in grams
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  prescribedItems PrescribedItem[]

  @@map("medications")
}

model Prescription {
  id             String             @id @default(uuid())
  consultationId String
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  pharmacistId   String?
  status         PrescriptionStatus @default(pending)

  prescribedItems PrescribedItem[]
  consultation    Consultation     @relation(fields: [consultationId], references: [id])
  pharmacist      Pharmacist?      @relation(fields: [pharmacistId], references: [id])

  @@map("prescriptions")
}

model PrescribedItem {
  id             String   @id @default(uuid())
  medicationId   String
  dosage         String
  frequency      String
  duration       String
  prescriptionId String
  createdAt      DateTime @default(now())

  medication   Medication   @relation(fields: [medicationId], references: [id])
  prescription Prescription @relation(fields: [prescriptionId], references: [id])
}

model LabRequest {
  id              String           @id @default(uuid())
  consultationId  String
  testType        LabTestType
  status          LabRequestStatus @default(pending)
  labTechnicianId String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  consultation  Consultation   @relation(fields: [consultationId], references: [id])
  labTechnician LabTechnician? @relation(fields: [labTechnicianId], references: [id])
  labResult     LabResult?

  @@map("lab_requests")
}

model LabResult {
  id           String   @id @default(uuid())
  labRequestId String   @unique
  resultData   String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  labRequest LabRequest @relation(fields: [labRequestId], references: [id])

  @@map("lab_results")
}

model Bill {
  id        String   @id @default(uuid())
  patientId String
  amount    Float
  status    String   @default("unpaid")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient        Patient         @relation(fields: [patientId], references: [id])
  paymentRecords PaymentRecord[]

  @@map("bills")
}

model PaymentRecord {
  id        String   @id @default(uuid())
  billId    String
  amount    Float
  method    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bill Bill @relation(fields: [billId], references: [id])

  @@map("payment_records")
}
